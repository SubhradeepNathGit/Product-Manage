<div class="page-header">
    <div>
        <h1 style="font-size: 2rem; font-weight: 700;">Edit Product Details</h1>
        <p style="color: var(--text-muted); font-size: 0.875rem;">Modify the product information and update the
            inventory.</p>
    </div>
</div>

<div class="form-card" style="max-width: 1000px;">
    <% if(errors) { %>
        <div
            style="background-color: #FEE2E2; color: #991B1B; padding: 1rem; border-radius: 8px; margin-bottom: 2rem; border: 1px solid #FECACA;">
            <% errors.forEach(err=> { %>
                <p class="mb-1 fw-500">
                    <%= err.message %>
                </p>
                <% }) %>
        </div>
        <% } %>

            <form action="/admin/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data">
                <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
                    <div class="form-group">
                        <label for="name">Product Name</label>
                        <input type="text" name="name" id="name" value="<%= product.name %>" required
                            style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border); background: var(--white); font-size: 0.875rem; color: var(--text-dark); transition: var(--transition);">
                    </div>
                    <div class="form-group">
                        <label for="price">Price (₹)</label>
                        <input type="number" name="price" id="price" value="<%= product.price %>" min="0" required
                            style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border); background: var(--white); font-size: 0.875rem; color: var(--text-dark); transition: var(--transition);">
                    </div>
                    <div class="form-group">
                        <label for="category">Category</label>
                        <select name="category" id="category" required
                            style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border); background: var(--white); font-size: 0.875rem; color: var(--text-dark); transition: var(--transition); appearance: none;">
                            <% categories.forEach(cat=> { %>
                                <option value="<%= cat._id %>" <%=product.category.toString()===cat._id.toString()
                                    ? 'selected' : '' %>><%= cat.name %>
                                </option>
                                <% }) %>
                        </select>
                    </div>
                </div>

                <div class="form-group" style="margin-bottom: 2rem; display: flex; align-items: center; gap: 0.75rem;">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="inStock" id="inStock" <%=product.inStock
                            ? 'checked' : '' %>
                        style="width: 2.5rem; height: 1.25rem; cursor: pointer;">
                        <label class="form-check-label ms-2" for="inStock" style="font-weight: 600; cursor: pointer;">
                            Product is currently in stock
                        </label>
                    </div>
                </div>

                <div class="form-group" style="margin-bottom: 2rem;">
                    <label for="description">Detailed Description</label>
                    <textarea name="description" id="description" rows="5" required
                        style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border); background: var(--white); font-size: 0.875rem; color: var(--text-dark); resize: vertical;"><%= product.description %></textarea>
                </div>

                <div class="row align-items-center mb-5 p-4 rounded-3"
                    style="background: var(--background-light); border: 2px dashed var(--border); border-radius: 12px; margin: 0 0 2rem 0;">
                    <div class="col-md-3 text-center border-end"
                        style="border-right: 1px solid var(--border) !important;">
                        <span
                            style="display: block; color: var(--text-muted); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; margin-bottom: 1rem;">Current
                            Visual</span>
                        <div
                            style="width: 120px; height: 120px; background: var(--white); border-radius: 8px; overflow: hidden; border: 1px solid var(--border); margin: 0 auto; padding: 4px;">
                            <img src="<%= product.image && (product.image.startsWith('http://') || product.image.startsWith('https://')) ? product.image : '/uploads/' + product.image %>"
                                alt="Current visual"
                                style="width: 100%; height: 100%; object-fit: cover; border-radius: 4px;">
                        </div>
                    </div>
                    <div class="col-md-9 ps-md-5 mt-4 mt-md-0">
                        <label for="image">Replace Product Image (Optional)</label>
                        <input type="file" name="image" id="image" accept="image/*"
                            style="width: 100%; max-width: 400px; display: block; margin-top: 1rem;">
                        <small style="color: var(--text-muted); display: block; margin-top: 0.75rem;">
                            <i class="bi bi-info-circle me-1"></i>Leave empty to keep the current image. Max size: 5MB.
                        </small>
                    </div>
                </div>

                <div
                    style="display: flex; gap: 1rem; justify-content: flex-end; border-top: 1px solid var(--border); padding-top: 2rem;">
                    <a href="/admin/products" class="view-btn"
                        style="min-width: 151px; text-align: center; line-height: 1.5;">Discard Changes</a>
                    <button type="submit" class="add-btn" style="min-width: 200px;">
                        <span>Update Details</span>
                    </button>
                </div>
            </form>
</div>
<div class="page-header">
    <div>
        <h1 style="font-size: 2rem; font-weight: 700;">Overview Dashboard</h1>
        <p style="color: var(--text-muted); font-size: 0.875rem;">Welcome back! Here's what's happening today.</p>
    </div>
</div>

<div class="stat-cards-grid">
    <div class="stat-card">
        <div class="stat-card-info">
            <h3>Total Products</h3>
            <div class="display-4">
                <%= productsCount %>
            </div>
            <a href="/admin/products" class="btn btn-link p-0 mt-2 text-decoration-none fw-600"
                style="font-size: 0.875rem;">
                Manage Products →
            </a>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-card-info">
            <h3>Total Categories</h3>
            <div class="display-4">
                <%= categoriesCount %>
            </div>
            <a href="/admin/categories" class="btn btn-link p-0 mt-2 text-decoration-none fw-600"
                style="font-size: 0.875rem;">
                Manage Categories →
            </a>
        </div>
    </div>
</div>

<div class="form-card"
    style="max-width: 100%; border-style: dashed; background: transparent; text-align: center; padding: 3rem;">
    <h2 style="font-weight: 700; margin-bottom: 0.5rem;">Quick Actions</h2>
    <p style="color: var(--text-muted); margin-bottom: 2rem;">Streamline your workflow with these helpful shortcuts.</p>

    <div style="display: flex; gap: 1rem; justify-content: center;">
        <a href="/admin/products/add" class="add-btn">
            <span>Add New Product</span>
        </a>
        <a href="/admin/categories/add" class="add-btn"
            style="background: var(--white); color: var(--primary); border: 1px solid var(--border);">
            <span>Add Category</span>
        </a>
    </div>
</div>